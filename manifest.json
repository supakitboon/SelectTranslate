{
  "manifest_version": 3,
  "name": "SelectLang",
  "version": "1.0.0",
  "description": "Highlight any word to instantly translate, analyze, and build your vocabulary.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SelectLang"
  }
}
